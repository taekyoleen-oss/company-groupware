# Supabase (필수)
# 대시보드 → Project Settings → API
#   Project URL → NEXT_PUBLIC_SUPABASE_URL (본인 프로젝트 전용, 예: https://abcd1234efgh.supabase.co)
#   anon public   → NEXT_PUBLIC_SUPABASE_ANON_KEY
# 문서/튜토리얼에 나오는 your-project.supabase.co 는 예시일 뿐이며 DNS에 없어 로그인이 절대 되지 않습니다. 반드시 대시보드에 표시된 URL을 복사하세요.
# Authentication → URL Configuration: Site URL / Redirect URLs에 Vercel 주소(예: https://xxx.vercel.app)를 등록하세요.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 프로덕션 공개 URL (OAuth 리다이렉트·카카오 공유 링크 등)
# Vercel 배포 후: https://<프로젝트>.vercel.app 또는 커스텀 도메인
NEXT_PUBLIC_APP_URL=

# 관리자 API 등 서버 전용 (Vercel Environment Variables에서만 설정, NEXT_PUBLIC 붙이지 않음)
SUPABASE_SERVICE_ROLE_KEY=

# 카카오 공유 SDK (사용 시)
# NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=
